# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
!groups/_gateway/
groups/main/*
groups/global/*
groups/_gateway/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md
!groups/_gateway/acl.example.json

# Secrets
*.keys.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# Per-installation PM2 overrides (the canonical files are
# ecosystem.config.cjs and start-nanoclaw.cjs). Use a different filename
# locally if you need custom ports / cwd / process name.
ecosystem.*.config.cjs
start-*.cjs
!start-nanoclaw.cjs
