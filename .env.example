SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# === LLM backend ===
# Which provider the credential-proxy forwards container LLM calls to.
# Default 'anthropic'. Set 'openrouter' to route through openrouter.ai
# instead — useful for non-Claude models (e.g. z-ai/glm-4.6v) or to
# leverage OpenRouter's unified billing.
# LLM_BACKEND=anthropic

# OpenRouter API key (https://openrouter.ai). Required when
# LLM_BACKEND=openrouter. Format: sk-or-v1-...
# OPENROUTER_API_KEY=

# OpenRouter upstream URL override. Defaults to https://openrouter.ai/api
# (Anthropic-Skin endpoint — keep this unless you're proxying OR yourself).
# OPENROUTER_BASE_URL=

# Anthropic upstream URL override. Defaults to https://api.anthropic.com.
# ANTHROPIC_BASE_URL=
