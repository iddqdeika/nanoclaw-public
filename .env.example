SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# === LLM backend ===
# Which provider the credential-proxy forwards container LLM calls to.
# Default 'anthropic'. Set 'openrouter' to route through openrouter.ai
# instead — useful for non-Claude models (e.g. z-ai/glm-4.6v) or to
# leverage OpenRouter's unified billing.
# LLM_BACKEND=anthropic

# OpenRouter API key (https://openrouter.ai). Required when
# LLM_BACKEND=openrouter. Format: sk-or-v1-...
# OPENROUTER_API_KEY=

# OpenRouter upstream URL override. Defaults to https://openrouter.ai/api
# (Anthropic-Skin endpoint — keep this unless you're proxying OR yourself).
# OPENROUTER_BASE_URL=

# Anthropic upstream URL override. Defaults to https://api.anthropic.com.
# ANTHROPIC_BASE_URL=

# Rate-limit fallback chain — comma-separated model IDs the agent tries
# in order after the SDK default fails. Format matches the active
# backend's model-id convention.
#   anthropic-direct:  claude-haiku-4-5,claude-opus-4-7
#   openrouter:        anthropic/claude-haiku-4.5,anthropic/claude-opus-4.7
# Leave unset to use the backend-appropriate default chain.
# NANOCLAW_MODEL_PRIORITY=

# Claude Agent SDK default-model overrides. Force the SDK to pick a
# specific model for each tier instead of its built-in Sonnet / Opus /
# Haiku names. Useful with LLM_BACKEND=openrouter to route the SDK's
# default attempt through a non-Anthropic model (e.g. z-ai/glm-4.6v)
# from the start rather than only on fallback.
# Set the model ID in whatever format the active backend accepts.
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=
